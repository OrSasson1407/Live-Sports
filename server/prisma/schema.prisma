// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Add Enum for strict typing
enum MatchStatus {
  LIVE
  FINISHED
  NOT_STARTED
  CANCELED
}

model Tournament {
  id        String   @id @default(uuid())
  name      String
  country   String
  matches   Match[]
}

model Team {
  id           String    @id @default(uuid())
  name         String
  logoUrl      String?
  
  homeMatches  Match[]   @relation("HomeTeam")
  awayMatches  Match[]   @relation("AwayTeam")
  
  // NEW: Relation to get all players in this team
  players      Player[]
}

model Match {
  id           String      @id @default(uuid())
  status       MatchStatus @default(NOT_STARTED) // 2. Use Enum
  homeScore    Int         @default(0)
  awayScore    Int         @default(0)
  startTime    DateTime
  
  // 3. Add Timestamps
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])

  homeTeamId   String
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  
  awayTeamId   String
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])

  // NEW: Relation to fetch live events (goals, cards, subs) for this specific match
  events       MatchEvent[]

  // 4. ADD INDEXES to prevent full-table scans
  @@index([status, startTime])
  @@index([tournamentId])
}


// ==========================================
// NEW MODELS FOR 365SCORES UPGRADE
// ==========================================

model Player {
  id           String       @id @default(uuid())
  name         String
  position     String       // e.g., 'Forward', 'Midfielder', 'Defender', 'Goalkeeper'
  jerseyNumber Int?
  
  teamId       String
  team         Team         @relation(fields: [teamId], references: [id])
  
  // Relation to track all events this player was involved in
  events       MatchEvent[]
  
  // Index for faster lookups when loading a team's squad
  @@index([teamId])
}

model MatchEvent {
  id        String   @id @default(uuid())
  type      String   // e.g., 'GOAL', 'YELLOW_CARD', 'RED_CARD', 'SUBSTITUTION'
  minute    Int
  
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  
  // Indexes for faster lookups when opening a specific match view
  @@index([matchId])
  @@index([playerId])
}